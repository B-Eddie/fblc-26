# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url_here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# reCAPTCHA v2 Configuration (Checkbox Challenge)
# Get this from: https://www.google.com/recaptcha/admin
# You need to register your site with reCAPTCHA v2 (Checkbox) type
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=your_recaptcha_site_key_here
# Server-side secret key (optional, for backend verification)
RECAPTCHA_SECRET_KEY=your_recaptcha_secret_key_here
